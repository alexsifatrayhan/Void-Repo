<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_bg"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="VOID REPO"
        android:textColor="@color/white"
        android:textSize="32sp"
        android:textStyle="bold"
        android:letterSpacing="0.2" />

    <TextView
        android:id="@+id/tv_credential"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/credential_text"
        android:textColor="@color/accent_color"
        android:textSize="14sp"
        android:layout_marginTop="4dp" />

    <LinearLayout
        android:id="@+id/ll_main_switch"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:background="@drawable/glass_background"
        android:gravity="center"
        android:orientation="vertical"
        android:layout_marginTop="40dp">

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/state_unlocked"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:layout_marginBottom="16dp" />

        <Switch
            android:id="@+id/switch_lock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:scaleX="2"
            android:scaleY="2" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="24dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/glass_background"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/panic_mode"
                android:textColor="@color/white"
                android:layout_centerVertical="true" />

            <Switch
                android:id="@+id/switch_panic"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true" />
        </RelativeLayout>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/glass_background"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/stealth_mode"
                android:textColor="@color/white"
                android:layout_centerVertical="true" />

            <Switch
                android:id="@+id/switch_stealth"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true" />
        </RelativeLayout>

    </LinearLayout>

    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <Button
        android:id="@+id/btn_select_files"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Select Files"
        android:backgroundTint="@color/glass_bg"
        android:textColor="@color/white" />

</LinearLayout>
